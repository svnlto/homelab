{
  "$schema": "https://raw.githubusercontent.com/jetify-com/devbox/0.14.2/.schema/devbox.schema.json",
  "packages": [
    "ansible@2.20.4",
    "ansible-lint@25.8.2",
    "molecule@25.12.0",
    "pre-commit@4.5.1",
    "tflint@0.61.0",
    "jq@1.8.1",
    "just@1.49.0",
    "terragrunt@1.0.1",
    "opentofu@1.11.6",
    "kubernetes-helm@3.20.1",
    "kubectl@1.35.3",
    "talosctl@1.12.6",
    "k9s@0.50.18",
    "argocd@3.3.6",
    "vcluster@0.31.0",
    "helm-docs@1.14.2",
    "kubeconform@0.7.0",
    "nodejs@25.9.0",
    "deno@2.7.12"
  ],
  "env": {
    "K9S_CONFIG_DIR": "~/.config/k9s"
  },
  "shell": {
    "init_hook": [
      "KUBE_SHARED=\"$PWD/infrastructure/prod/compute/k8s-shared/configs/kubeconfig-shared\"",
      "[ -f \"$KUBE_SHARED\" ] && export KUBECONFIG=\"$KUBE_SHARED\"",
      "TALOS_SHARED=\"$PWD/infrastructure/prod/compute/k8s-shared/configs/talosconfig-shared\"",
      "[ -f \"$TALOS_SHARED\" ] && export TALOSCONFIG=\"$TALOS_SHARED\""
    ]
  }
}
